# ==============================================================
# .env.example — IARA Chat Greenfield (Fitness UNIC)
# Copie para .env no servidor n8n e preencha os valores reais.
# NUNCA comite o .env com valores reais — só este .env.example.
# ==============================================================

# --------------------------------------------------------------
# Anthropic — LLM principal
# --------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# --------------------------------------------------------------
# Evolution API V2 — canal WhatsApp
# --------------------------------------------------------------
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=xxx
# Nome da instância Evolution configurada para a Fitness UNIC
EVOLUTION_INSTANCE=FitnessUNIC
# Secret usado para validar HMAC SHA-256 do webhook Evolution
EVOLUTION_HMAC_SECRET=xxx

# --------------------------------------------------------------
# Supabase — banco de dados
# Use SEMPRE a service_role key (bypassa RLS). NUNCA a anon key.
# --------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------------------------
# Google Calendar — agendamento de Aula Experimental
# --------------------------------------------------------------
GOOGLE_CALENDAR_ID=primary
# Para autenticação service account: defina a key como JSON minificado
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# Alternativa: access token de curta duração (requer refresh periódico)
GOOGLE_CALENDAR_ACCESS_TOKEN=

# --------------------------------------------------------------
# Chatwoot — handoff para humano
# Reaproveita instância self-hosted do V19 (Hostinger).
# CHATWOOT_INBOX_ID: definir após auditoria das inboxes V19.
# --------------------------------------------------------------
CHATWOOT_URL=https://chatwoot.seudominio.com
CHATWOOT_API_TOKEN=xxx
CHATWOOT_INBOX_ID=<definir-pos-auditoria-v19>
# Secret para validar webhook HMAC do Chatwoot
CHATWOOT_HMAC_SECRET=xxx

# --------------------------------------------------------------
# System Prompt da IARA
# Caminho absoluto do arquivo no servidor n8n.
# O arquivo prompts/system_prompt_iara_v1.txt deve estar
# acessível neste path pelo processo do n8n.
# Ex: /home/node/greenfield-iara-chat/prompts/system_prompt_iara_v1.txt
# --------------------------------------------------------------
IARA_SYSTEM_PROMPT_PATH=/home/node/greenfield-iara-chat/prompts/system_prompt_iara_v1.txt
